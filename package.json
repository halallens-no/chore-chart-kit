{
  "name": "chore-chart-kit",
  "version": "0.1.0",
  "description": "Free, open-source library of printable chore chart templates. JSON-defined, SVG/PDF renderable, CC-BY-4.0 licensed.",
  "homepage": "https://printablechorechart.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/halallens-no/chore-chart-kit.git"
  },
  "bugs": {
    "url": "https://github.com/halallens-no/chore-chart-kit/issues"
  },
  "license": "(CC-BY-4.0 AND MIT)",
  "author": "Flinkis <hello@printablechorechart.com>",
  "keywords": [
    "chore-chart",
    "printable",
    "template",
    "pdf",
    "svg",
    "parenting",
    "kids",
    "open-source"
  ],
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "src",
    "templates",
    "samples"
  ],
  "scripts": {
    "validate": "ajv validate --spec=draft2020 -s templates/schema.json -d \"templates/chore-charts/*.json\"",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:samples": "npm run build && node scripts/build-samples.mjs"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^20.11.0",
    "ajv-cli": "^5.0.0",
    "pdf-lib": "^1.17.1",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
